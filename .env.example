# ============================================
# The Agency — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- API Keys (at least one required for agents to work) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=          # Optional: shared secret for gateway auth
OPENCLAW_PORT=18789              # Gateway WebSocket port

# --- Configurator UI ---
CONFIGURATOR_PORT=3000           # Web UI port
